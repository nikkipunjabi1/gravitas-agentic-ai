# =============================================================================
# Gravitas Transformation Co-Pilot — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# Server-only modules import these via process.env.*; client modules never do
# (except those prefixed NEXT_PUBLIC_).
# =============================================================================

# --- Models -------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# NOTE — use 127.0.0.1 (not `localhost`) for local URLs on Windows + Node 18+.
# DNS resolves `localhost` to IPv6 (::1) first; undici's fetch only tries the
# first returned address; local servers bind to 0.0.0.0 (IPv4) by default;
# the connection fails. 127.0.0.1 forces IPv4 and avoids resolution.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_REASONING_MODEL=deepseek-r1
OLLAMA_FAST_MODEL=qwen3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Vector store -------------------------------------------------------------
CHROMA_URL=http://127.0.0.1:8000
CHROMA_KB_COLLECTION=gravitas-kb

# --- Crawl worker -------------------------------------------------------------
CRAWL_WORKER_URL=http://127.0.0.1:8787
CRAWL_WORKER_SHARED_SECRET=replace-me-with-a-long-random-string

# --- Google PageSpeed Insights (Lighthouse via Google's IPs) -----------------
# The crawler calls Google PSI as the PRIMARY data source — it returns full
# Lighthouse data (perf, a11y, SEO) for any public URL, and Google's IPs
# aren't blocked by Cloudflare / Akamai / F5 like our own would be.
#
# Optional but strongly recommended in production. Without a key, PSI works
# but on a low-quota shared pool (~1-5 req/sec). With a key: 400/sec, 25k/day.
# Get one from https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_INSIGHTS_API_KEY=

# --- KB ingest ----------------------------------------------------------------
GRAVITAS_SITEMAP_URL=https://thisisgravitas.com/sitemap.xml
KB_REFRESH_CRON=0 4 * * *

# --- Supabase -----------------------------------------------------------------
# Server-only (service role bypasses RLS — never expose to the browser).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Browser-safe anon credentials used by /admin/login. Same URL + anon key as
# above; the NEXT_PUBLIC_ prefix is what Next exposes to the client bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SIGNING_SECRET=replace-me-with-a-long-random-string

# --- Cost cap (see docs/ARCHITECTURE.md → Cost cap) ---------------------------
DAILY_COST_CAP_USD=50
COST_CAP_RESET_TZ=UTC

# --- Per-IP rate limits (see docs/ARCHITECTURE.md → Rate limiting) -----------
IP_DAILY_TURN_LIMIT=20
IP_DAILY_AUDIT_LIMIT=1
COUNTER_VISIBLE_THRESHOLD=5
# Dev-only: rate limits are auto-bypassed when NODE_ENV !== "production". Set
# this to "true" if you want to test the rate-limit code path locally.
IP_QUOTA_FORCE_ENFORCE=false

# --- Admin panel + logging (see docs/ADMIN_PANEL.md) -------------------------
ADMIN_EMAIL_DOMAIN=thisisgravitas.com
SESSION_RETENTION_DAYS=90

# --- Cron jobs ---------------------------------------------------------------
# Shared secret for /api/cron/* endpoints. Must be set in production; cron
# trigger sends `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=replace-me-with-a-long-random-string

# --- Branding — audit-report closing contact (see docs/BRANDING.md) ----------
BRANDING_CLOSING_CONTACT_NAME=
BRANDING_CLOSING_CONTACT_ROLE=
BRANDING_CLOSING_CONTACT_PHONE=
BRANDING_CLOSING_CONTACT_EMAIL=

# --- SMTP for KB ingest notifications (Phase 1.8) ----------------------------
# Recipients + on-success / on-failure toggles live in admin_settings; SMTP
# transport credentials live HERE. The worker uses nodemailer; Gmail /
# Google Workspace App Passwords work natively (port 465, secure on).
#
# For Gmail: enable 2FA, then generate an App Password from
# https://myaccount.google.com/apppasswords. Paste the 16-char password
# (spaces stripped) into SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=noreply@thisisgravitas.com
SMTP_PASSWORD=
EMAIL_FROM_NAME=Gravitas Co-Pilot
