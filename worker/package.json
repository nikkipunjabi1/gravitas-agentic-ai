{
  "name": "@gravitas/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Gravitas Co-Pilot crawl worker — Playwright + Cheerio + Lighthouse. Phase 0 ships the scaffold; Phase 1 adds the real crawler.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "kb:reseed": "tsx src/kb-ingest.ts --reseed",
    "setup:browsers": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "nodemailer": "^6.9.16",
    "playwright": "^1.48.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
